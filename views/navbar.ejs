<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand-link">
      <span class="brand-mark" aria-hidden="true">
        <i data-lucide="messages-square" class="icon" aria-hidden="true"></i>
      </span>
      <span class="brand-text">Clubhouse</span>
    </a>
    <div class="nav-actions">
      <% if(user){ %>
      <a href="/add-msg" class="nav-link nav-link-strong">
        <i data-lucide="square-pen" class="icon" aria-hidden="true"></i>
        Add Message
      </a>
      <button
        class="profile-button"
        id="profileBtn"
        type="button"
        aria-expanded="false"
        aria-controls="dropdown"
      >
        <%= user.first_name.charAt(0)+user.last_name.charAt(0) %>
      </button>
      <div id="dropdown" class="profile-menu flex-col" aria-hidden="true">
        <a href="/join" class="menu-link">
          <i data-lucide="key-round" class="icon" aria-hidden="true"></i>
          Join Club
        </a>
        <form action="/logout" method="post">
          <button type="submit" class="menu-button">
            <i data-lucide="log-out" class="icon" aria-hidden="true"></i>
            Logout
          </button>
        </form>
      </div>
      <% } else { %>
      <a href="/login" class="nav-link">
        <i data-lucide="log-in" class="icon" aria-hidden="true"></i>
        Login
      </a>
      <a href="/sign-up" class="nav-link nav-link-strong">
        <i data-lucide="user-plus" class="icon" aria-hidden="true"></i>
        Sign Up
      </a>
      <% } %>
    </div>
  </div>
</nav>

<script>
  const profile = document.getElementById("profileBtn");
  if (profile) {
    const dropdown = document.getElementById("dropdown");
    const setDropdownOpen = (isOpen) => {
      dropdown.classList.toggle("is-open", isOpen);
      dropdown.setAttribute("aria-hidden", String(!isOpen));
      profile.setAttribute("aria-expanded", String(isOpen));
    };

    profile.addEventListener("click", () => {
      setDropdownOpen(!dropdown.classList.contains("is-open"));
    });

    document.addEventListener("click", (event) => {
      if (!profile.contains(event.target) && !dropdown.contains(event.target)) {
        setDropdownOpen(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setDropdownOpen(false);
      }
    });
  }
</script>
