<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="styles.css" />
    <title>Join Club</title>
  </head>
  <body>
    <%- include("navbar.ejs", {user}) %>
    <main class="app-main">
      <h1 class="page-title">Join Club</h1>
      <%- include("errors.ejs") %>
      <div class="join-grid">
        <section class="join-panel">
          <div class="join-panel-header">
            <h2 class="panel-title">Become a Member</h2>
            <p class="form-hint">
              Riddle: I speak without a mouth and hear without ears. I have no
              body, but I come alive with the wind.
            </p>
          </div>
          <form action="/member" method="post" class="form-stack">
            <div class="field-group">
              <label for="memberSecret" class="field-label">Password</label>
              <input
                type="password"
                name="secret"
                id="memberSecret"
                class="text-field"
                required
              />
            </div>
            <button type="submit" class="button-primary">
              <i data-lucide="key-round" class="icon" aria-hidden="true"></i>
              Submit
            </button>
          </form>
        </section>
        <section class="join-panel">
          <div class="join-panel-header">
            <h2 class="panel-title">Become an Admin</h2>
            <p class="form-hint">
              Use the admin password to unlock moderation access.
            </p>
          </div>
          <form action="/admin" method="post" class="form-stack">
            <div class="field-group">
              <label for="adminSecret" class="field-label">Password</label>
              <input
                type="password"
                name="secret"
                id="adminSecret"
                class="text-field"
                required
              />
            </div>
            <button type="submit" class="button-primary">
              <i data-lucide="shield-check" class="icon" aria-hidden="true"></i>
              Submit
            </button>
          </form>
        </section>
      </div>
      <div class="form-footer">
        <a href="/" class="text-link">
          <i data-lucide="arrow-left" class="icon" aria-hidden="true"></i>
          Go to Dashboard
        </a>
      </div>
    </main>
    <%- include("lucide.ejs") %>
  </body>
</html>
