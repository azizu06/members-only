<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="styles.css" />
    <title>Join Club</title>
  </head>
  <body>
    <%- include("navbar.ejs", {user}) %>
    <main class="app-main">
      <h1 class="page-title">Join Club</h1>
      <div class="join-grid">
        <section class="join-panel">
          <h2 class="message-title">Become Member</h2>
          <p class="form-hint">
            Riddle: I am the house where members gather, stories stay inside,
            and the door opens when you say my name.
          </p>
          <%- include("errors.ejs") %>
          <form action="/member" method="post" class="form-stack">
            <div class="field-group">
              <label for="secret" class="field-label">Password</label>
              <input
                type="password"
                name="secret"
                id="secret"
                class="text-field"
                required
              />
            </div>
            <button type="submit" class="button-primary">Submit</button>
          </form>
        </section>
        <section class="join-panel">
          <h2 class="message-title">Become Admin</h2>
          <%- include("errors.ejs") %>
          <form action="/admin" method="post" class="form-stack">
            <div class="field-group">
              <label for="secret" class="field-label">Password</label>
              <input
                type="password"
                name="secret"
                id="secret"
                class="text-field"
                required
              />
            </div>
            <button type="submit" class="button-primary">Submit</button>
          </form>
        </section>
      </div>
      <div class="form-footer">
        <a href="/" class="text-link">Go to Dashboard</a>
      </div>
    </main>
  </body>
</html>
