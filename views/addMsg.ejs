<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="styles.css" />
    <title>Add Message</title>
  </head>
  <body>
    <%- include("navbar.ejs") %>
    <main class="app-main app-main-narrow">
      <h1 class="page-title">Add Message</h1>
      <%- include("errors.ejs") %>
      <div class="form-panel">
        <form action="/add-msg" method="post" class="form-stack">
          <div class="field-group">
            <label for="title" class="field-label">Title</label>
            <input type="text" name="title" id="title" class="text-field" required />
          </div>
          <div class="field-group">
            <label for="message" class="field-label">Message</label>
            <textarea name="message" id="message" class="text-field" required></textarea>
          </div>
          <button type="submit" class="button-primary">Send</button>
        </form>
        <div class="form-footer">
          <a href="/" class="text-link">Go to Dashboard</a>
        </div>
      </div>
    </main>
  </body>
</html>
